# ============================================================
# RAG Document Chatbot — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to GitHub — only commit this file.
# ============================================================

# ---- Groq API (free at groq.com) ----
# Sign up at https://console.groq.com → API Keys → Create API Key
GROQ_API_KEY=gsk_your_key_here
GROQ_MODEL=llama3-8b-8192

# ---- Ollama (local development only) ----
# Make sure Ollama is running: ollama serve
# Pull your model first:       ollama pull llama3.2
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.2:latest

# ---- Embedding Model (runs locally via sentence-transformers) ----
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2
EMBEDDING_VECTOR_DIM=384

# ---- Chunking ----
CHUNK_SIZE=400
CHUNK_OVERLAP=50

# ---- Vector Store ----
# Options: flat | hnsw | ivf
VECTOR_STORE_TYPE=flat

# ---- Retriever ----
RETRIEVER_TOP_K=3
RETRIEVER_SCORE_THRESHOLD=0.1

# ---- LLM Parameters ----
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=512

# ---- API Server ----
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1

# ---- Logging ----
# Options: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
